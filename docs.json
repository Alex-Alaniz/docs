{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "OpenClaws",
  "description": "Deploy your own 24/7 AI assistant with 1000+ integrations. Managed OpenClaw hosting by BearifiedCo.",
  "colors": {
    "primary": "#DC2626",
    "light": "#F4F4F5",
    "dark": "#0A0A0A"
  },
  "logo": {
    "light": "/images/logo.svg",
    "dark": "/images/logo.svg",
    "href": "https://openclaws.biz"
  },
  "favicon": "/images/logo.svg",
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "decoration": "gradient"
  },
  "navigation": {
    "global": {
      "tabs": [
        {
          "tab": "Documentation",
          "href": "/",
          "icon": "book"
        },
        {
          "tab": "Guides",
          "href": "/guides",
          "icon": "compass"
        }
      ],
      "anchors": [
        {
          "anchor": "Discord",
          "href": "https://discord.gg/bearified",
          "icon": "discord"
        },
        {
          "anchor": "OpenClaw Docs",
          "href": "https://docs.openclaw.ai",
          "icon": "arrow-up-right-from-square"
        }
      ]
    },
    "groups": [
      {
        "group": "Getting Started",
        "pages": ["index", "quickstart", "control-ui"]
      },
      {
        "group": "Features",
        "pages": ["chat", "toolkits", "skills", "channels", "cron-jobs"]
      },
      {
        "group": "Configuration",
        "pages": ["models", "byo-keys", "agents", "sessions", "nodes"]
      },
      {
        "group": "Infrastructure",
        "pages": ["gateway", "config", "debug-logs", "usage"]
      },
      {
        "group": "Guides",
        "pages": ["guides/connect-gmail", "guides/connect-github", "guides/setup-telegram", "guides/schedule-briefing"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/Alex-Alaniz/openclaws"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://openclaws.biz/login"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/openclaws",
      "github": "https://github.com/Alex-Alaniz/openclaws",
      "discord": "https://discord.gg/bearified"
    },
    "links": [
      {
        "header": "Product",
        "items": [
          { "label": "Dashboard", "href": "https://openclaws.biz/dashboard" },
          { "label": "Pricing", "href": "https://openclaws.biz/#pricing" },
          { "label": "Toolkits", "href": "https://openclaws.biz/dashboard/toolkits" }
        ]
      },
      {
        "header": "Legal",
        "items": [
          { "label": "Privacy Policy", "href": "https://openclaws.biz/privacy" },
          { "label": "Terms of Service", "href": "https://openclaws.biz/terms" }
        ]
      }
    ]
  },
  "search": {
    "prompt": "Search OpenClaws docs..."
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  }
}
